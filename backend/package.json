{
  "type": "module",
  "name": "shareinfo-backend",
  "version": "1.0.0",
  "description": "社内情報共有システム バックエンド",
  "main": "index.js",
  "scripts": {
    "dev": "npx tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:gen": "dotenv -e .env.local -- prisma generate --schema=./prisma/schema.prisma",
    "migrate:dev": "dotenv -e .env.local -- prisma migrate dev --schema=./prisma/schema.prisma",
    "migrate:reset": "dotenv -e .env.local -- prisma migrate reset --schema=./prisma/schema.prisma",
    "migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy --schema=./prisma/schema.prisma",
    "studio": "dotenv -e .env.local -- prisma studio --schema ./prisma/schema.prisma",
    "seed": "dotenv -e .env.local -- npx tsx prisma/seed.ts",
    "typecheck": "npx tsc -p tsconfig.json --noEmit"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.1.0",
    "@prisma/client": "^6.2.1",
    "argon2": "^0.44.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.1",
    "fastify": "^5.5.0",
    "fastify-plugin": "^5.0.1",
    "prisma": "^6.2.1",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.3.0",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2"
  }
}
